# Copy this file to ".env" (same folder as Export-JiraTree.ps1) and fill in your
# own values. .env is git-ignored, so your token never gets committed.

# Your Jira Cloud site URL
JIRA_SITE=https://your-domain.atlassian.net

# Atlassian account email used for API authentication
JIRA_EMAIL=you@example.com

# Atlassian API token — create one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# There is no JIRA_ROOT_ISSUE here on purpose: the root issue key changes on
# every run, so the script always prompts for it (or pass it directly, e.g.
# `Export-JiraTree.bat KAN-183` or `-RootIssue KAN-183`).
